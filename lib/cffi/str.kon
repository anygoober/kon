@[data]
pub struct CStr {
    start: *const c_str
}

pub fn CStr.from_raw(ptr: *const c_str) -> CStr {
    if ptr == null_ptr {
        @panic("got null pointer in CStr.from_raw()");
    }

    CStr { start: ptr }
}

/// Gets the length of the C string without the null terminator.
pub fn CStr.len(str) -> usize {
    let mut cursor = str.start;
    while (*cursor != '\0') {
        cursor += 1;
    }

    cursor - str.start
}

pub fn CStr.as_ptr(str) -> *const c_str {
    str.start
}
